{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Edit",
      "Write",
      "Bash(pdftotext *)",
      "Bash(git add *)",
      "Bash(git -C * add *)",
      "Bash(git commit *)",
      "Bash(git -C * commit *)",
      "Bash(git push*)",
      "Bash(git -C * push*)",
      "Bash(git pull*)",
      "Bash(git -C * pull*)",
      "Bash(git status*)",
      "Bash(git -C * status*)",
      "Bash(git log*)",
      "Bash(git -C * log*)",
      "Bash(git diff*)",
      "Bash(git -C * diff*)",
      "Bash(cd * && git add*)",
      "Bash(cd * && git commit*)",
      "Bash(cd * && git push*)",
      "Bash(cd * && git pull*)",
      "Bash(cd * && git status*)",
      "Bash(cd * && git log*)",
      "Bash(cd * && git diff*)",
      "Bash(cd * && git stash*)",
      "Bash(cd * && git rebase*)",
      "Bash(cd * && git rev-list*)",
      "Bash(cd * && python3*)",
      "Bash(cd * && python3 -c*)",
      "Bash(awk *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(rm *.lock)",
      "Bash(mkdir *)",
      "Bash(curl *)",
      "Bash(node *)",
      "Bash(node -e *)",
      "Bash(python3 *)",
      "Bash(python3 -c *)",
      "Bash(git -C * rev-list *)",
      "Bash(git rev-list *)",
      "Bash(git -C * stash*)",
      "Bash(git stash*)",
      "Bash(git -C * rebase*)",
      "Bash(git rebase*)",
      "Bash(cp *)",
      "Bash(cat *)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "git pull origin main --ff-only 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Syncing skills from GitHub..."
          }
        ]
      }
    ]
  }
}

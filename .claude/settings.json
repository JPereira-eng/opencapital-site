{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Edit",
      "Write(**/*.html)",
      "Write(**/sources.json)",
      "Write(**/registry.json)",
      "Bash(pdftotext *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(head *)",
      "Bash(wc *)",
      "Bash(ls *)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "git pull origin main --ff-only 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Syncing skills from GitHub..."
          }
        ]
      }
    ]
  }
}

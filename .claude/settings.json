{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Edit",
      "Write",
      "Bash(*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "git pull origin main --ff-only 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Syncing skills from GitHub..."
          }
        ]
      }
    ]
  }
}
